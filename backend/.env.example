# ============================================
# LLM Provider Configuration (OpenRouter)
# ============================================
# API key for OpenRouter service - used to access various LLM models through OpenRouter platform
OPENROUTER_API_KEY=

# API key for Google AI/Generative AI services - used as a fallback or alternative LLM provider
GOOGLE_AI_API_KEY=

# ============================================
# Stock Data APIs
# ============================================
# Alpha Vantage API key - provides real-time and historical stock market data, technical indicators, and more
ALPHA_VANTAGE_API_KEY=

# ============================================
# News APIs
# ============================================
# NewsAPI.org API key - aggregates news articles from various sources for market sentiment analysis
NEWSAPI_KEY=

# GNews API key - alternative news aggregation service for fetching financial and business news
GNEWS_API_KEY=

# ============================================
# Cache & Server Configuration
# ============================================
# Redis connection URL - used for caching API responses and session storage to improve performance
REDIS_URL=redis://localhost:6379

# Cache Time-To-Live in seconds - default expiration time for cached data (3600 seconds = 1 hour)
CACHE_TTL=3600

# ============================================
# LLM Model Configuration
# ============================================
# Default LLM model to use via OpenRouter - specifies which AI model to use for text generation and analysis
LLM_MODEL=openrouter/google/gemma-4-31b-it:free
